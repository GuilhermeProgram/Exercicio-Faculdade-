<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Exposição de Artistas</title>
    <link rel="stylesheet" href="BASE.CSS">
    <script defer src="base.js"></script>
</head>
<body>
    <header>
        <div class="Header"></div>
        <img src="Spotify_icon.svg.png" alt="ICON">
        <input type="text" id="search" placeholder="Buscar artistas...">
    </header>
    <div class="carousel">
        <button class="prev">&#10094;</button>
        <div class="carousel-container">
            <img src="1900x1900-000000-80-0-0.jpg" alt="Artista 1">
            <img src="channels4_profile.jpg" alt="Artista 2">
            <img src="20230207_183154.jpg" alt="Artista 3">
        </div>
        <button class="next">&#10095;</button>
    </div>
</body>
</html>
------------------------------------------------------------------
body {
    font-family: Arial, sans-serif;
    margin: 0;
    padding: 0;
    text-align: center;
    background-color: #000000;
}

header#div {
    background: #000000;
    color: rgb(255, 255, 255);
    padding: 10px;
}
img {
    width: 1%;
    padding-right: 10px;
}

#search {
    padding: 10px;
    width: 50%;
    max-width: 350px;
    border-radius: 500px;
    color: rgb(255, 255, 255);
    background-color: black;
    margin-right: 1420px;
}

.carousel {
    position: relative;
    width: 80%;
    margin: 20px auto;
    overflow: hidden;
    background: rgb(0, 0, 0);
    border-radius: 10px;
}

.carousel-container {
    display: flex;
    transition: transform 0.5s ease-in-out;
    
}

.carousel img {
    width: 32.3%;
    max-width: 50%;
    border-radius: 600px;
}

button.prev, button.next {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background: rgba(255, 255, 255, 0.5);
    color: rgb(0, 0, 0);
    border: none;
    padding: 5px;
    cursor: pointer;
    border-radius: 10px;
}

button.prev { left: 50px; }
button.next { right: 10px; }

#artists-container {
    display: flex;
    justify-content: center;
    gap: 20px;
    margin: 20px 0;
}

.artist {
    background: rgb(236, 236, 236);
    padding: 20px;
    border-radius: 20%;
    box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);
    cursor: pointer;
    font-weight: bold;
}

-------------------------------------------------------
document.addEventListener("DOMContentLoaded", () => {
    // Barra de pesquisa
    const searchInput = document.getElementById("search");
    const artists = document.querySelectorAll(".artist");

    searchInput.addEventListener("input", () => {
        const query = searchInput.value.toLowerCase();
        artists.forEach(artist => {
            const name = artist.getAttribute("data-name").toLowerCase();
            artist.style.display = name.includes(query) ? "block" : "none";
        });
    });

    // Carrossel
    const carouselContainer = document.querySelector(".carousel-container");
    const images = document.querySelectorAll(".carousel-container img");
    const prevButton = document.querySelector(".prev");
    const nextButton = document.querySelector(".next");
    let index = 0;

    function updateCarousel() {
        carouselContainer.style.transform = `translateX(-${index * 100}%)`;
    }

    nextButton.addEventListener("click", () => {
        index = (index + 1) % images.length;
        updateCarousel();
    });

    prevButton.addEventListener("click", () => {
        index = (index - 1 + images.length) % images.length;
        updateCarousel();
    });

    // Banners flutuantes (desaparecem após 5 segundos)
    const banner = document.querySelector(".floating-banner");
    setTimeout(() => {
        banner.style.display = "none";
    }, 5000);
});
